# Twilio WhatsApp
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Django (local dev defaults)
DJANGO_SECRET_KEY=your-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=*

# Production overrides (set these on Render dashboard)
# DJANGO_DEBUG=False
# DJANGO_ALLOWED_HOSTS=.onrender.com,yourdomain.com
# DJANGO_CSRF_TRUSTED_ORIGINS=https://your-frontend.pages.dev,https://yourdomain.com
# DJANGO_CORS_ALLOWED_ORIGINS=https://your-frontend.pages.dev,https://yourdomain.com

# Database (local dev uses PostGIS local defaults)
# DB_NAME=muip
# DB_USER=postgres
# DB_PASSWORD=27769
# DB_HOST=localhost
# DB_PORT=5432

# On Render: set DATABASE_URL to your Neon PostGIS connection string
# Example: postgres://user:pass@ep-silent-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
# Go to Neon dashboard -> Databases -> connection string -> copy

# Celery / Redis (optional for dev; set on Render if using background tasks)
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0

# GDAL (only needed on Windows for local dev)
# GDAL_LIBRARY_PATH=C:\Program Files\PostgreSQL\18\bin\libgdal-35.dll
# GEOS_LIBRARY_PATH=C:\Program Files\PostgreSQL\18\bin\libgeos_c.dll
